{
  "name": "@sms-monitor/web",
  "version": "0.0.1",
  "private": true,
  "description": "SMS Monitor v2.0 web admin (Next.js 14, App Router, shadcn/ui, Tailwind)",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "npx jest --config jest.config.ts",
    "test:api": "npx jest --config jest.config.api.ts",
    "test:all": "npx jest --config jest.config.ts && npx jest --config jest.config.api.ts",
