# SMS Monitor v2.0 Backend — environment example
# Copy to .env and fill in real values. Never commit .env to git.

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://sms_monitor:sms_monitor_dev@localhost:5432/sms_monitor?schema=public

# Redis (BullMQ + rate limiting)
REDIS_URL=redis://localhost:6379

# Auth
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production-this-is-a-dev-only-32-byte-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# Device HMAC (replay protection window in seconds)
DEVICE_HMAC_TOLERANCE_SECONDS=300

# Tenancy
DEFAULT_RETENTION_DAYS=90
