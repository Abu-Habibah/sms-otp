# SMS Monitor v2.0 — Environment Variables
# Copy this file to .env and update the values.

# Database
DATABASE_URL=postgresql://sms_monitor:sms_monitor_dev@localhost:6003/sms_monitor

# Redis
REDIS_URL=redis://localhost:6004

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-random-secret
# Separate key for refresh token hashing (optional, defaults to JWT_SECRET)
# Generate with: openssl rand -hex 32
REFRESH_TOKEN_SECRET=change-me-to-a-random-secret

# Backend
PORT=3000
NODE_ENV=development

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
